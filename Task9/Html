
<!DOCTYPE html>
<html>
<head>
  <title>Fetch API</title>
</head>
<body>

<h2>User Data</h2>
<button onclick="loadData()">Load Users</button>

<ul id="users"></ul>

<script>
function loadData() {
  fetch("https://jsonplaceholder.typicode.com/users")
    .then(res => res.json())
    .then(data => {
      let output = "";

      data.forEach(user => {
        output += `<li>${user.name} - ${user.email}</li>`;
      });

      document.getElementById("users").innerHTML = output;
    });
}
</script>

</body>
</html>
