
<!DOCTYPE html>
<html>
<head>
  <title>Dashboard</title>
</head>
<body>

<h2>Student Dashboard</h2>

<select id="sort">
  <option value="">Sort</option>
  <option value="name">Name</option>
  <option value="dob">DOB</option>
</select>

<input type="text" id="dept" placeholder="Department">

<button onclick="loadData()">Load</button>

<table border="1">
  <thead>
    <tr>
      <th>Name</th><th>Email</th><th>DOB</th><th>Dept</th><th>Phone</th>
    </tr>
  </thead>
  <tbody id="table"></tbody>
</table>

<h3>Department Count</h3>
<ul id="count"></ul>

<script>
function loadData() {
  const sort = document.getElementById("sort").value;
  const dept = document.getElementById("dept").value;

  fetch(`http://localhost:3000/students?sort=${sort}&dept=${dept}`)
  .then(res => res.json())
  .then(data => {
    let rows = "";
    data.forEach(s => {
      rows += `<tr>
        <td>${s.name}</td>
        <td>${s.email}</td>
        <td>${s.dob}</td>
        <td>${s.department}</td>
        <td>${s.phone}</td>
      </tr>`;
    });
    document.getElementById("table").innerHTML = rows;
  });

  // COUNT
  fetch("http://localhost:3000/count")
  .then(res => res.json())
  .then(data => {
    let list = "";
    data.forEach(c => {
      list += `<li>${c.department} : ${c.count}</li>`;
    });
    document.getElementById("count").innerHTML = list;
  });
}
</script>

</body>
</html>
